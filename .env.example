# Destinatário e rota padrão (também editáveis em runtime via comandos)
NOTIFY_EMAIL=seu-email@exemplo.com
ORIGIN=Fortaleza
DESTINATION=Recife
TRAVEL_DATE=15/09/2026
SEARCH_SITE=all
SEARCH_LIMIT=15

# SMTP (produção / Brevo)
# SMTP_PASSWORD deve ser a SMTP Key COMPLETA (~90+ chars: xsmtpsib-...-...)
# Chave truncada causa erro 535 Authentication failed.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Use true para testar sem SMTP (salva HTML em data/last_email.html)
SMTP_DRY_RUN=true

# Local: use "data". Docker Compose sobrescreve para /app/data
BUS_SCRAP_DATA_DIR=data
TZ=America/Sao_Paulo
